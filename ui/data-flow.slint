export struct SlintMediaFile {
	id: int,
	name: string,
	artist: string,
	path: string,
	extension: string,
	file_size: int,
}

export struct SlintQueueItem {
	media_id: int,
	currently_playing: bool,
}

export struct SlintTimeLine {
	current: int,
	length: int
}

export global SlintState {
	in-out property<[SlintMediaFile]> index;
	in-out property<[SlintQueueItem]> queue;
	in property<SlintTimeLine> currently_playing;
}

export global SettingActions {
	callback new_local_source();
}

export global MediaActions {
	callback media_change(int);
	callback media_start(int);
	callback media_toggle();
	callback media_loop();
	callback media_mix();

	// Media track
	callback media_change_track_position(int);
	callback media_get_track_position();
}
