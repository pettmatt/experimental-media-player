import { Button, VerticalBox, HorizontalBox } from "std-widgets.slint";
import { SideBar } from "side-bar.slint";
import { MainList } from "main-list.slint";
import { MediaControllers } from "media-controllers.slint";
import { Queue } from "queue.slint";

global Palette {
	in-out property<color> primary-text: #191b20;
	in-out property<color> primary-background: #808597;
}

export component AppWindow inherits Window {
	preferred-width: 100%;
    preferred-height: 100%;

	property<physical-length> gl-margin: 5px;
	property<physical-length> gl-padding: 5px;

	callback media_mix();
	callback media_change(int);
	callback media_start(bool);
	callback media_loop(bool);

	callback new_local_source();

    main-view := HorizontalBox {
		x: 0px;
		y: 0px;
		width: 100%;

		if root.width > 500px:
			SideBar { playlists: []; y: 0; }

		MainList { list: []; min-width: root.width * 60%; }

		if root.width > 700px:
			Queue { y: 0; }
	}

	vertical-view := VerticalBox {
		x: 0px;
		y: parent.height - self.height;
		height: 150px;

		Button {
			text: "test";
			clicked => { root.new_local_source() }
		}

		if root.width < 500px:
			SideBar { }

		if root.width < 700px:
			Queue { }

		MediaControllers {
			
		}
	}
}
