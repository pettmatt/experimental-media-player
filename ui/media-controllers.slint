import { HorizontalBox, VerticalBox, Button, Slider } from "std-widgets.slint";
import { MediaActions, SlintState, SlintTimeLine } from "data-flow.slint";
import { VolumeSlider } from "components/volume-slider.slint";

export component MediaControllers {
	in property<SlintTimeLine> playing;

	Timer {
		property<int> count: 0;
		interval: 1000ms;
		running: SlintState.timeline.length > 0
			? true
			: false;
		triggered() => {
			MediaActions.media_get_track_position();
		}
	}

	VerticalBox {
		HorizontalBox {
			Button { text: @tr("mix"); clicked => { MediaActions.media_mix() } }
			Button { text: @tr("prev"); clicked => { MediaActions.media_change(-1) } }
			Button { text: @tr("start"); clicked => { MediaActions.media_toggle() } }
			Button { text: @tr("next"); clicked => { MediaActions.media_change(1) } }
			Button { text: @tr("loop"); clicked => { MediaActions.media_loop() } }
			Button { text: @tr("volume"); clicked => { MediaActions.media_loop() } }
			Rectangle {
				bg := Rectangle {
					width: 25px;
					height: 25px;
					background: Colors.pink;

					ta := TouchArea {
						height: vs.visible
							? parent.height + vs.height
							: parent.height;
					}

					vs := VolumeSlider {
						settings: SlintState.settings;
						width: parent.width;
						y: -parent.height / 2- 5px;
					}
				}

				states [
					inactive when !ta.has-hover && !vs.has-focus: {
						bg.background: Colors.beige;
						vs.visible: false;
					}
					active-hover when ta.has-hover || vs.has-focus: {
						bg.background: Colors.aqua;
						vs.visible: true;
					}
				]
			}
		}

		HorizontalBox {
			Text { text: playing.current / 60; }
			Slider {
				width: 90%;
				height: 10px;
				value: playing.current / playing.length / 60;
			}
			Text { text: playing.length / 60; }
		}
	}
}
