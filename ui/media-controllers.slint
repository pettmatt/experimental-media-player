import { HorizontalBox, VerticalBox, Button } from "std-widgets.slint";

export component MediaControllers {
	in property<{
		time: {
			current: string,
			length: string
		}
	}> playing;

	callback mix_audio();
	callback start(bool);
	callback loop_audio(bool);
	callback change_audio(int);

	VerticalBox {
		HorizontalBox {
			Button { text: "mix"; clicked => { mix_audio() } }
			Button { text: "prev"; clicked => { change_audio(-1) } }
			Button { text: "start"; clicked => { start(true) } }
			Button { text: "next"; clicked => { change_audio(1) } }
			Button { text: "loop"; clicked => { loop_audio(true) } }
		}

		HorizontalBox {
			Text { text: root.playing.time.current; }
			Rectangle { background: orange; }
			Text { text: root.playing.time.length; }
		}
	}
}
