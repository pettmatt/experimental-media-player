import { ListView, HorizontalBox } from "std-widgets.slint";
import { MediaActions as ma, SlintMediaFile, SlintMediaFile, SlintState } from "data-flow.slint";
import { Palette } from "style.slint";

export component Queue {
	Text { text: "Queue"; }

	for item in SlintState.queue: Text {
		text: item.id;
	}

	ListView {
		height: parent.height;
		
		for item in SlintState.queue: Rectangle {
			background: pink;
			height: 30px;

			Text { text: "test text"; }
			TouchArea {
				clicked => {
					ma.media_start(item.id);
				}

				Rectangle {
					height: 30px;
					background: Palette.secondary-background;

					HorizontalBox {
						alignment: start;

						Text { text: item.id; }
						Text { text: item.name; }
					}
				}
			}
		}
	}
}
