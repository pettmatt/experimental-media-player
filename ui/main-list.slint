			// 	Menu {
			// 		MenuItem {
			// 			title: @tr("Add to queue");
			// 			// icon: "";
			// 			activated() => {}
			// 		}

			// 		Menu {
			// 			title: @tr("Add to playlist");
			// 			// icon: "";

			// 			for playlist in playlists: MenuItem {
			// 				title: playlist.name;
			// 				activated() => {
			// 					MediaActions.add_to_playlist(playlist.id, media.id);
			// 				}
			// 			}
			// 		}
			// 	}
			// }
		}
	}
}
